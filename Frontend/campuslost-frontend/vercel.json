{
  "buildCommand": "ng build --configuration production",
  "outputDirectory": "dist/campuslost-frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://campuslost-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}